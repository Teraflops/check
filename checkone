import java.awt.AWTException;
import java.awt.Dimension;
import java.awt.MouseInfo;
import java.awt.Point;
import java.awt.Robot;
import java.awt.Toolkit;
import java.awt.event.KeyEvent;
import java.util.Random;

public class MouseMover {
    // Shared state variables
    private static volatile long lastActiveTime = System.currentTimeMillis();
    private static volatile Point expectedMousePos = MouseInfo.getPointerInfo().getLocation();

    public static void main(String[] args) {
        System.out.println("Starting MouseMover. Press Ctrl+C in the console to stop.");

        // Start the background thread to monitor true user mouse movements
        Thread monitorThread = new Thread(() -> {
            Point lastCheckedPos = MouseInfo.getPointerInfo().getLocation();
            while (true) {
                try {
                    Point currentMousePos = MouseInfo.getPointerInfo().getLocation();
                    
                    // If the mouse moved, and it wasn't the program that moved it
                    if (!currentMousePos.equals(lastCheckedPos) && !currentMousePos.equals(expectedMousePos)) {
                        lastActiveTime = System.currentTimeMillis();
                    }
                    
                    lastCheckedPos = currentMousePos;
                    Thread.sleep(100); // Check every 100ms
                } catch (InterruptedException e) {
                    e.printStackTrace();
                } catch (Exception e) {
                    // Ignore exceptions if mouse info cannot be fetched temporarily
                }
            }
        });
        monitorThread.setDaemon(true);
        monitorThread.start();

        // Main automation loop
        try {
            Robot robot = new Robot();
            Random random = new Random();
            Dimension screenSize = Toolkit.getDefaultToolkit().getScreenSize();
            
            int screenWidth = (int) screenSize.getWidth();
            int screenHeight = (int) screenSize.getHeight();
            
            while (true) {
                long idleTime = System.currentTimeMillis() - lastActiveTime;
                
                // If idle for more than 20 minutes (20 * 60 * 1000 = 1,200,000 ms)
                if (idleTime > 1200000) {
                    System.out.println("Idle time exceeded 20 minutes. Opening Notepad and typing...");
                    openNotepadAndType(robot, random);
                    // Reset idle time to avoid opening notepad repeatedly immediately
                    lastActiveTime = System.currentTimeMillis();
                    
                    // Update expected pos after typing
                    expectedMousePos = MouseInfo.getPointerInfo().getLocation();
                }
                
                // Move mouse to a random location
                int randomX = random.nextInt(screenWidth);
                int randomY = random.nextInt(screenHeight);
                
                // Update expected pos BEFORE moving so the monitor thread knows it's us
                expectedMousePos = new Point(randomX, randomY);
                robot.mouseMove(randomX, randomY);
                System.out.println("Moved mouse to: " + randomX + ", " + randomY);
                
                // Switch screens (Alt + Tab)
                System.out.println("Switching screens (Alt+Tab)...");
                robot.keyPress(KeyEvent.VK_ALT);
                robot.keyPress(KeyEvent.VK_TAB);
                robot.keyRelease(KeyEvent.VK_TAB);
                robot.keyRelease(KeyEvent.VK_ALT);
                
                // Wait for 1 minute (60,000 ms)
                Thread.sleep(60000);
            }
        } catch (AWTException | InterruptedException e) {
            e.printStackTrace();
        }
    }
    
    private static void openNotepadAndType(Robot robot, Random random) {
        try {
            // Open Run dialog (Windows Key + R)
            robot.keyPress(KeyEvent.VK_WINDOWS);
            robot.keyPress(KeyEvent.VK_R);
            robot.keyRelease(KeyEvent.VK_R);
            robot.keyRelease(KeyEvent.VK_WINDOWS);
            
            Thread.sleep(500); // Wait for Run dialog
            
            // Type "notepad"
            typeString(robot, "notepad");
            
            // Press Enter
            robot.keyPress(KeyEvent.VK_ENTER);
            robot.keyRelease(KeyEvent.VK_ENTER);
            
            Thread.sleep(2000); // Wait for Notepad to open
            
            // Type random keystrokes (20 random characters)
            for (int i = 0; i < 20; i++) {
                // Generate a random lowercase letter (a-z)
                int keyCode = KeyEvent.VK_A + random.nextInt(26);
                robot.keyPress(keyCode);
                robot.keyRelease(keyCode);
                Thread.sleep(100);
            }
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
    }
    
    private static void typeString(Robot robot, String text) {
        for (char c : text.toCharArray()) {
            int keyCode = KeyEvent.getExtendedKeyCodeForChar(c);
            if (KeyEvent.CHAR_UNDEFINED == keyCode) {
                throw new RuntimeException("Key code not found for character '" + c + "'");
            }
            robot.keyPress(keyCode);
            robot.keyRelease(keyCode);
            try {
                Thread.sleep(50);
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
    }
}
